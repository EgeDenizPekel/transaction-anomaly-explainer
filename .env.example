# LLM Provider: "ollama" for local dev, "openai" for production
LLM_PROVIDER=ollama

# Required if LLM_PROVIDER=openai
OPENAI_API_KEY=sk-...

# Ollama base URL (default when running locally)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# MLflow
MLFLOW_TRACKING_URI=http://localhost:5000

# API
API_HOST=0.0.0.0
API_PORT=8000

# Model registry
MLFLOW_MODEL_NAME=anomaly-detector
MLFLOW_MODEL_STAGE=Production
